digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 218\lEnd\lScript End", shape=oval];
    3 [label="Line 209\lTry\lTry", shape=box];
    4 [label="Line 213\lFinally\lFinally", shape=box];
    5 [label="Line 210\lPipelineAst\lWrite-Host \"exception\"", shape=box];
    6 [label="Line 211\lReturn\lreturn", shape=box];
    7 [label="Line 214\lPipelineAst\lWrite-Host \"finally\"", shape=box];
    8 [label="Line 215\lPipelineAst\lwrite-host \"xixi\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 5;
    5 -> 6;
    5 -> 4 [label="Exception"];
    6 -> 4 [label="Return"];
    4 -> 7;
    7 -> 8;
    8 -> 2 [label="Uncaught Exception"];
    8 -> 2 [label="Return"];
}