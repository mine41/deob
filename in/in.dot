digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 207\lEnd\lScript End", shape=oval];
    3 [label="Line 58\lAssignmentStatementAst\l$flag = $true", shape=box];
    4 [label="Line 59\lAssignmentStatementAst\l$count = 0", shape=box];
    5 [label="Line 61\lIf Condition\lIf Condition", shape=box];
    6 [label="Line 61\lCondition\l$flag -and $count -eq 0", shape=diamond];
    7 [label="Line 62\lAssignmentStatementAst\l$count = 1", shape=box];
    8 [label="Line 63\lCondition\l-not $flag", shape=diamond];
    9 [label="Line 64\lAssignmentStatementAst\l$count = 2", shape=box];
    10 [label="Line 65\lElse\lImplicit Else", shape=box];
    11 [label="Line 65\lMerge\lIf-End", shape=point];
    12 [label="Line 66\lPipelineAst\lwrite-host $count", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 5;
    5 -> 6 [label="Condition"];
    6 -> 7;
    6 -> 8 [label="False"];
    8 -> 9;
    8 -> 10 [label="False"];
    7 -> 11;
    9 -> 11;
    10 -> 11;
    11 -> 12;
    12 -> 2;
}