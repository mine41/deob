digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Id 1\lStart\lScript Start", shape=oval];
    2 [label="Id 2\lEnd\lScript End", shape=oval];
    3 [label="Id 3\lMainStart\lMain Script", shape=box];
    4 [label="Id 4\lMainEnd\lEnd Main Script", shape=box];
    5 [label="Id 5\lAssignmentStatementAst\l$a = 'i' + 'ex'\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    6 [label="Id 6\lAssignmentStatementAst\l$b = 10 + 20\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    7 [label="Id 7\lAssignmentStatementAst\l$c = 1..3\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];

    // Edges
    1 -> 3;
    3 -> 5;
    5 -> 6;
    6 -> 7;
    7 -> 4;
    4 -> 2;
}