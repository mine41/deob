digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 35\lEnd\lScript End", shape=oval];
    3 [label="Line 1\lAssignmentStatementAst\l$a = 3", shape=box];
    4 [label="Line 2\lIf Condition\lIf Condition", shape=box];
    5 [label="Line 2\lCondition\l$a -gt 0", shape=diamond];
    6 [label="Line 3\lIf Condition\lIf Condition", shape=box];
    7 [label="Line 3\lCondition\l$a -eq 3", shape=diamond];
    8 [label="Line 4\lReturn\lreturn \"3\"", shape=box];
    9 [label="Line 5\lElse\lImplicit Else", shape=box];
    10 [label="Line 5\lMerge\lIf-End", shape=point];
    11 [label="Line 6\lAssignmentStatementAst\l$x = 100", shape=box];
    12 [label="Line 7\lElse\lElse", shape=box];
    13 [label="Line 8\lReturn\lreturn \"neg\"", shape=box];
    14 [label="Line 9\lMerge\lIf-End", shape=point];
    15 [label="Line 10\lAssignmentStatementAst\l$end = \"finish\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 5 [label="Condition"];
    5 -> 6;
    6 -> 7 [label="Condition"];
    7 -> 8;
    8 -> 2 [label="Return"];
    6 -> 9 [label="Else"];
    9 -> 10;
    10 -> 11;
    4 -> 12 [label="Else"];
    12 -> 13;
    13 -> 2 [label="Return"];
    11 -> 14;
    14 -> 15;
    15 -> 2;
}