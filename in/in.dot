digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 212\lEnd\lScript End", shape=oval];
    3 [label="Line 95\lAssignmentStatementAst\l$outer = 0", shape=box];
    4 [label="Line 96\lTry\lTry", shape=box];
    5 [label="Line 111\lFinally\lFinally", shape=box];
    6 [label="Line 102\lCatch\lCatch [System.DivideByZeroException]", shape=box];
    7 [label="Line 106\lCatch\lCatch [All]", shape=box];
    8 [label="Line 97\lAssignmentStatementAst\l$outer = 10", shape=box];
    9 [label="Line 98\lAssignmentStatementAst\l$inner = 1", shape=box];
    10 [label="Line 99\lPipelineAst\l$inner++", shape=box];
    11 [label="Line 100\lThrow\lthrow \"error with outer=$outer inner=$inner\"", shape=box];
    12 [label="Line 103\lPipelineAst\lWrite-Host $outer", shape=box];
    13 [label="Line 108\lAssignmentStatementAst\l$catchMsg = $_.Exception.Message", shape=box];
    14 [label="Line 109\lAssignmentStatementAst\l$outer = 20", shape=box];
    15 [label="Line 113\lPipelineAst\l$outer++", shape=box];
    16 [label="Line 114\lAssignmentStatementAst\l$final = $outer", shape=box];
    17 [label="Line 115\lPipelineAst\lWrite-Host \"in finally, outer=$outer final=$fi...", shape=box];
    18 [label="Line 116\lMerge\lTry-End", shape=point];
    19 [label="Line 118\lPipelineAst\lWrite-Host \"after try/catch/finally, outer=$ou...", shape=box];
    20 [label="Line 173\lPipelineAst\lWrite-Host \"swVar = $swVar msg = $msg\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 8;
    8 -> 9;
    9 -> 10;
    10 -> 11;
    8 -> 6 [label="Exception"];
    9 -> 6 [label="Exception"];
    10 -> 6 [label="Exception"];
    11 -> 6 [label="Exception"];
    6 -> 12;
    6 -> 7 [label="Not Match"];
    7 -> 13;
    13 -> 14;
    7 -> 5 [label="Uncaught Exception"];
    12 -> 5;
    14 -> 5;
    5 -> 15;
    15 -> 16;
    16 -> 17;
    17 -> 2 [label="Uncaught Exception"];
    17 -> 18;
    18 -> 19;
    19 -> 20;
    20 -> 2;
}