digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 218\lEnd\lScript End", shape=oval];
    3 [label="Line 190\lFunctionDef\lfunction Test-Try-finally-return", shape=box];
    4 [label="Line 190\lFuncStart\lfunction Test-Try-finally-return", shape=oval];
    5 [label="Line 199\lFuncEnd\lEnd function Test-Try-finally-return", shape=oval];
    6 [label="Line 191\lTry\lTry", shape=box];
    7 [label="Line 195\lFinally\lFinally", shape=box];
    8 [label="Line 192\lPipelineAst\lWrite-Host \"before return\"", shape=box];
    9 [label="Line 193\lPipelineAst\lWrite-Host \"after return\"", shape=box];
    10 [label="Line 196\lPipelineAst\lwrite-host \"function-finally\"", shape=box];
    11 [label="Line 197\lMerge\lTry-End", shape=point];
    12 [label="Line 198\lPipelineAst\lWrite-Host \"after finally\"", shape=box];
    13 [label="Line 201\lPipelineAst\lwrite-host \"before xixi\"", shape=box];
    14 [label="Line 202\lPipelineAst\lTest-Try-finally-return", shape=box];
    15 [label="Line 203\lPipelineAst\lwrite-host \"xixi\"", shape=box];

    // Edges
    1 -> 3;
    4 -> 6;
    6 -> 8;
    8 -> 9;
    8 -> 7 [label="Exception"];
    9 -> 7 [label="Exception"];
    9 -> 7;
    7 -> 10;
    10 -> 5 [label="Uncaught Exception"];
    10 -> 11;
    11 -> 12;
    12 -> 5;
    3 -> 13;
    13 -> 14;
    14 -> 15;
    15 -> 2;
}