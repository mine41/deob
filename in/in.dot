digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Id 1\lStart\lScript Start", shape=oval];
    2 [label="Id 2\lEnd\lScript End", shape=oval];
    3 [label="Id 3\lAssignmentStatementAst\l$globalX = 100", shape=box];
    4 [label="Id 4\lFunctionDef\lfunction Outer-Func", shape=box];
    5 [label="Id 5\lFuncStart\lfunction Outer-Func", shape=oval];
    6 [label="Id 6\lFuncEnd\lEnd function Outer-Func", shape=oval];
    7 [label="Id 7\lFuncParams\lparam([int]$x)", shape=box];
    8 [label="Id 8\lAssignmentStatementAst\l$y = $x + 1", shape=box];
    9 [label="Id 9\lFunctionDef\lfunction Inner-Func", shape=box];
    10 [label="Id 10\lFuncStart\lfunction Inner-Func", shape=oval];
    11 [label="Id 11\lFuncEnd\lEnd function Inner-Func", shape=oval];
    12 [label="Id 12\lFuncParams\lparam([int]$z)", shape=box];
    13 [label="Id 13\lAssignmentStatementAst\l$w = $globalX + $x + $y + $z", shape=box];
    14 [label="Id 14\lPipelineAst\lWrite-Host \"Inner-Func: w=$w\"", shape=box];
    15 [label="Id 15\lReturn\lreturn $w", shape=box];
    16 [label="Id 16\lAssignmentStatementAst\l$resultInner = Inner-Func 5", shape=box];
    17 [label="Id 17\lReturn\lreturn $resultInner", shape=box];
    18 [label="Id 18\lAssignmentStatementAst\l$outerRes = Outer-Func 3", shape=box];
    19 [label="Id 19\lPipelineAst\lWrite-Host \"Outer-Func result = $outerRes\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    5 -> 7;
    7 -> 8;
    8 -> 9;
    10 -> 12;
    12 -> 13;
    13 -> 14;
    14 -> 15;
    15 -> 11 [label="Return"];
    9 -> 16;
    16 -> 17;
    17 -> 6 [label="Return"];
    4 -> 18;
    18 -> 19;
    19 -> 2;
}