digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 6\lEnd\lScript End", shape=oval];
    3 [label="Line 1\lLoopStart\lfor ($i = 0; $i -lt 5; $i++)", shape=box];
    4 [label="Line 1\lCondition\lCondition: $i -lt 5", shape=diamond];
    5 [label="Line 5\lLoopEnd\lEnd For", shape=box];
    6 [label="Line 2\lIf Condition\lIf Condition", shape=box];
    7 [label="Line 2\lCondition\l$i -eq 2", shape=diamond];
    8 [label="Line 2\lContinue\lcontinue", shape=box];
    9 [label="Line 2\lElse\lImplicit Else", shape=box];
    10 [label="Line 2\lMerge\lIf-End", shape=point];
    11 [label="Line 3\lIf Condition\lIf Condition", shape=box];
    12 [label="Line 3\lCondition\l$i -eq 4", shape=diamond];
    13 [label="Line 3\lBreak\lbreak", shape=box];
    14 [label="Line 3\lElse\lImplicit Else", shape=box];
    15 [label="Line 3\lMerge\lIf-End", shape=point];
    16 [label="Line 4\lPipelineAst\lWrite-Output $i", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 6;
    6 -> 7 [label="Condition"];
    7 -> 8;
    8 -> 4 [label="Continue"];
    6 -> 9 [label="Else"];
    9 -> 10;
    10 -> 11;
    11 -> 12 [label="Condition"];
    12 -> 13;
    13 -> 5 [label="Break"];
    11 -> 14 [label="Else"];
    14 -> 15;
    15 -> 16;
    16 -> 4 [label="Next"];
    4 -> 5 [label="Condition False"];
    5 -> 2;
}