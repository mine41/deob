digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 251\lEnd\lScript End", shape=oval];
    3 [label="Line 81\lAssignmentStatementAst\l$a = 2", shape=box];
    4 [label="Line 83\lLoopStart\lfor ($i = 0; $i -lt 4; $i++)", shape=box];
    5 [label="Line 83\lForInit\l$i = 0", shape=box];
    6 [label="Line 83\lCondition\l$i -lt 4", shape=diamond];
    7 [label="Line 123\lLoopEnd\lEnd For", shape=box];
    8 [label="Line 83\lForIter\l$i++", shape=box];
    9 [label="Line 85\lPipelineAst\lWrite-Output \"Outer start $i\"", shape=box];
    10 [label="Line 88\lIf Condition\lIf Condition", shape=box];
    11 [label="Line 88\lCondition\l$i -eq 1", shape=diamond];
    12 [label="Line 89\lPipelineAst\lWrite-Output \"Continue outer\"", shape=box];
    13 [label="Line 90\lContinue\lcontinue", shape=box];
    14 [label="Line 91\lElse\lImplicit Else", shape=box];
    15 [label="Line 91\lMerge\lIf-End", shape=point];
    16 [label="Line 94\lLoopStart\lfor ($j = 0; $j -lt 3; $j++)", shape=box];
    17 [label="Line 94\lForInit\l$j = 0", shape=box];
    18 [label="Line 94\lCondition\l$j -lt 3", shape=diamond];
    19 [label="Line 114\lLoopEnd\lEnd For", shape=box];
    20 [label="Line 94\lForIter\l$j++", shape=box];
    21 [label="Line 96\lPipelineAst\lWrite-Output \"Inner $i,$j\"", shape=box];
    22 [label="Line 99\lIf Condition\lIf Condition", shape=box];
    23 [label="Line 99\lCondition\l$j -eq 0", shape=diamond];
    24 [label="Line 100\lContinue\lcontinue", shape=box];
    25 [label="Line 101\lElse\lImplicit Else", shape=box];
    26 [label="Line 101\lMerge\lIf-End", shape=point];
    27 [label="Line 104\lIf Condition\lIf Condition", shape=box];
    28 [label="Line 104\lCondition\l$j -eq 1 -and $i -eq 2", shape=diamond];
    29 [label="Line 105\lBreak\lbreak", shape=box];
    30 [label="Line 106\lElse\lImplicit Else", shape=box];
    31 [label="Line 106\lMerge\lIf-End", shape=point];
    32 [label="Line 109\lIf Condition\lIf Condition", shape=box];
    33 [label="Line 109\lCondition\l$i -eq 3 -and $j -eq 2", shape=diamond];
    34 [label="Line 110\lExit\lexit", shape=box];
    35 [label="Line 111\lElse\lImplicit Else", shape=box];
    36 [label="Line 111\lMerge\lIf-End", shape=point];
    37 [label="Line 113\lPipelineAst\lWrite-Output \"Inner body end\"", shape=box];
    38 [label="Line 117\lIf Condition\lIf Condition", shape=box];
    39 [label="Line 117\lCondition\l$i -eq $a", shape=diamond];
    40 [label="Line 118\lPipelineAst\lWrite-Output \"Break outer\"", shape=box];
    41 [label="Line 119\lBreak\lbreak", shape=box];
    42 [label="Line 120\lElse\lImplicit Else", shape=box];
    43 [label="Line 120\lMerge\lIf-End", shape=point];
    44 [label="Line 122\lPipelineAst\lWrite-Output \"Outer end $i\"", shape=box];
    45 [label="Line 125\lPipelineAst\lWrite-Output \"Script end\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 5;
    5 -> 6;
    6 -> 9;
    9 -> 10;
    10 -> 11 [label="Condition"];
    11 -> 12;
    12 -> 13;
    13 -> 8 [label="Continue"];
    11 -> 14 [label="False"];
    14 -> 15;
    15 -> 16;
    16 -> 17;
    17 -> 18;
    18 -> 21;
    21 -> 22;
    22 -> 23 [label="Condition"];
    23 -> 24;
    24 -> 20 [label="Continue"];
    23 -> 25 [label="False"];
    25 -> 26;
    26 -> 27;
    27 -> 28 [label="Condition"];
    28 -> 29;
    29 -> 19 [label="Break"];
    28 -> 30 [label="False"];
    30 -> 31;
    31 -> 32;
    32 -> 33 [label="Condition"];
    33 -> 34;
    34 -> 2 [label="Exit"];
    33 -> 35 [label="False"];
    35 -> 36;
    36 -> 37;
    37 -> 20;
    20 -> 18;
    18 -> 19 [label="Condition False"];
    19 -> 38;
    38 -> 39 [label="Condition"];
    39 -> 40;
    40 -> 41;
    41 -> 7 [label="Break"];
    39 -> 42 [label="False"];
    42 -> 43;
    43 -> 44;
    44 -> 8;
    8 -> 6;
    6 -> 7 [label="Condition False"];
    7 -> 45;
    45 -> 2;
}