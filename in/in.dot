digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Line 0\lStart\lScript Start", shape=oval];
    2 [label="Line 10\lEnd\lScript End", shape=oval];
    3 [label="Line 1\lAssignmentStatementAst\l$i = 0", shape=box];
    4 [label="Line 2\lLoopStart\lDoWhile", shape=box];
    5 [label="Line 9\lCondition\lCondition: $i -lt 5", shape=diamond];
    6 [label="Line 9\lLoopEnd\lEnd DoWhile", shape=box];
    7 [label="Line 3\lPipelineAst\lWrite-Output $i", shape=box];
    8 [label="Line 4\lIf Condition\lIf Condition", shape=box];
    9 [label="Line 4\lCondition\l$i -eq 2", shape=diamond];
    10 [label="Line 5\lContinue\lcontinue", shape=box];
    11 [label="Line 7\lElse\lImplicit Else", shape=box];
    12 [label="Line 7\lMerge\lIf-End", shape=point];
    13 [label="Line 8\lPipelineAst\l$i++", shape=box];
    14 [label="Line 10\lPipelineAst\lWrite-Output \"Done\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 7;
    7 -> 8;
    8 -> 9 [label="Condition"];
    9 -> 10;
    10 -> 5 [label="Continue"];
    8 -> 11 [label="Else"];
    11 -> 12;
    12 -> 13;
    13 -> 5;
    5 -> 4 [label="While True"];
    5 -> 6 [label="While False"];
    6 -> 14;
    14 -> 2;
}