digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label="Id 1\lStart\lScript Start", shape=oval];
    2 [label="Id 2\lEnd\lScript End", shape=oval];
    3 [label="Id 3\lAssignmentStatementAst\l$base = 10", shape=box];
    4 [label="Id 4\lAssignmentStatementAst\l$base2 = 11", shape=box];
    5 [label="Id 5\lAssignmentStatementAst\l$result = ($base * 2) + [Math]::Pow($base2, 2)", shape=box];
    6 [label="Id 6\lPipelineAst\lWrite-Host \"result = $result\"", shape=box];

    // Edges
    1 -> 3;
    3 -> 4;
    4 -> 5;
    5 -> 6;
    6 -> 2;
}