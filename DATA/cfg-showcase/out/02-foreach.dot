digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 1 | Start</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Script Start</FONT></B>>, shape=oval, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    2 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 2 | End</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Script End</FONT></B>>, shape=oval, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    3 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 3 | MainStart</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Main Script</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    4 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 4 | MainEnd</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">End Main Script</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    5 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 5 | AssignmentStatementAst</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$items = @('a', 'b')</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    6 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 6 | LoopStart</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">foreach ($item in $items)</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    7 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 7 | ForEachInit</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$__fe_29b69d77663c = $items; $__fe_29b69d77663c_idx = 0</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    8 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 8 | ForEachCondition</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">[bool]($__fe_29b69d77663c_idx -lt $__fe_29b69d77663c.Count)</FONT></B>>, shape=diamond, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    9 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 9 | LoopEnd</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">End ForEach</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    10 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 10 | ForEachBind</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$item = $__fe_29b69d77663c[$__fe_29b69d77663c_idx]</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    11 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 11 | ForEachIter</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$__fe_29b69d77663c_idx++</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    12 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 12 | PipelineElement</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Write-Output $item</FONT></B><BR ALIGN="LEFT"/><FONT POINT-SIZE="10" COLOR="#333333">RESOLVABLE: 1</FONT>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];

    // Edges
    1 -> 3;
    3 -> 5;
    5 -> 6;
    6 -> 7;
    7 -> 8;
    8 -> 9 [label="No more items"];
    8 -> 10 [label="Has next"];
    11 -> 8;
    10 -> 12;
    12 -> 11;
    9 -> 4;
    4 -> 2;
}