digraph G {
    rankdir=TB;
    node [
        fontname="Consolas"
        shape=box
        width=0
        height=0
        margin="0.2,0.1"
        fontsize=10
    ];
    edge [fontname="Arial", arrowhead=vee, fontsize=9];

    // Nodes
    1 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 1 | Start</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Script Start</FONT></B>>, shape=oval, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    2 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 2 | End</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Script End</FONT></B>>, shape=oval, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    3 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 3 | MainStart</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Main Script</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    4 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 4 | MainEnd</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">End Main Script</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    5 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 5 | AssignmentStatementAst</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$code = '$message = ''dynamic''; Write-Output $message'</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    6 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 6 | PipelineElement</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">&amp; $_dyn_5c147fd3</FONT></B><BR ALIGN="LEFT"/><FONT POINT-SIZE="10" COLOR="#333333">CALLS: Block: _dyn_5c147fd3</FONT><BR ALIGN="LEFT"/><FONT POINT-SIZE="10" COLOR="#333333">RESOLVABLE: 1</FONT>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    7 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 7 | BlockStart</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">DynamicBlock _dyn_5c147fd3</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    8 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 8 | BlockEnd</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">End DynamicBlock _dyn_5c147fd3</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    9 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 9 | AssignmentStatementAst</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">$message = 'dynamic'</FONT></B>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];
    10 [label=<<FONT POINT-SIZE="9" COLOR="#666666">Id 10 | PipelineElement</FONT><BR ALIGN="LEFT"/><B><FONT POINT-SIZE="16">Write-Output $message</FONT></B><BR ALIGN="LEFT"/><FONT POINT-SIZE="10" COLOR="#333333">RESOLVABLE: 1</FONT>>, shape=box, style="filled,rounded", fillcolor="#ffffff", color="#333333", penwidth=1];

    // Edges
    1 -> 3;
    3 -> 5;
    5 -> 6;
    6 -> 4;
    4 -> 2;
    7 -> 9;
    9 -> 10;
    10 -> 8;
}